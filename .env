# ─────────────────────────────────────────────────────────────
#  .env — Konfigurasi Environment
#  Salin file ini ke .env dan sesuaikan nilainya
#  JANGAN commit file .env ke version control!
# ─────────────────────────────────────────────────────────────

# ── Aplikasi ──────────────────────────────────────────────────
APP_NAME="ANN Brute-Force Detection Middleware"
APP_VERSION="1.0.0"
DEBUG=false

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT=0.5

# ── Model ANN ─────────────────────────────────────────────────
MODEL_PATH=saved_models/ann_model.pt
SCALER_PATH=saved_models/scaler.pkl
MODEL_INPUT_DIM=14
MODEL_HIDDEN_1=64
MODEL_HIDDEN_2=32

# ── Threshold Deteksi ─────────────────────────────────────────
# Tuning ini berpengaruh langsung pada false positive/negative
# Turunkan THRESHOLD_PASS  → lebih agresif menantang user
# Naikkan THRESHOLD_CHALLENGE → lebih sedikit yang diblokir
THRESHOLD_PASS=0.40
THRESHOLD_CHALLENGE=0.70

# ── Blokir ────────────────────────────────────────────────────
BLOCK_DURATION_S=900       # 15 menit
CHALLENGE_DELAY_S=2.0      # delay artifisial untuk score menengah

# ── Fallback Rate Limiter ─────────────────────────────────────
FALLBACK_MAX_REQUESTS=10
FALLBACK_WINDOW_S=60

# ── Logging ───────────────────────────────────────────────────
LOG_PATH=logs/security.log
LOG_LEVEL=INFO
